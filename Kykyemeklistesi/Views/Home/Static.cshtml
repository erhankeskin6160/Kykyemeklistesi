@section MetaTags {
    @* _Layout.cshtml zaten başlık ve açıklamayı ViewData dan alıyor *@
}

@{
    var sehirler = ViewBag.SelectedCity as List<SelectListItem>;
}

    <div class="main-layout d-flex flex-lg-row flex-column justify-content-center align-items-center">
        <!-- Sol Reklam Alanı -->
        <aside class="ad-left d-flex flex-column align-items-center order-1 order-lg-1">
            <div class="ad-banner mb-3">
                <!-- Static Sayfası Ana Reklam -->
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-5290089711270021"
                     data-ad-slot="4527260997"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
            </div>
            
            <div class="ad-banner d-none d-lg-block">
               <ins class="adsbygoogle"
                    style="display:block"
                    data-ad-client="ca-pub-5290089711270021"
                    data-ad-slot="4527260997"
                    data-ad-format="auto"
                    data-full-width-responsive="true"></ins>
            </div>
        </aside>

        <!-- Ana İçerik -->
        <div class="content-wrapper order-1 order-lg-2">
            <div class="page-header">
                <h1 class="text-white">📊 @ViewBag.secilen Kyk Yemek İstatistikleri</h1>
                <p class="text-white">Kyk yurtlarında en çok çıkan kyk yemekleri</p>
            </div>

            <form method="get">
       <div class="city-selector-container">
        <label for="selectedCity">🏙️ Şehir Seçin:</label>
        <select id="selectedCity" name="selectedCity" class="city-dropdown" onchange="redirectToCity(this)">
            @foreach (var item in ViewBag.SelectedCity as List<SelectListItem>)
            {
                <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>
           </form>

            <script>
                function redirectToCity(select) {
                    const city = select.value;
                    const url = `/kyk-yemek-listesi-istatistik/${encodeURIComponent(city)}`;
                    window.location.href = url;
                }
            </script>

            <div class="loading-spinner" id="loadingSpinner">
                <p>Yükleniyor...</p>
            </div>

            <div class="charts-grid">
                <div class="chart-card">
                    <div class="chart-wrapper">
                        @Html.Partial("_CorbaStaticPartial.cshtml", (IEnumerable<dynamic>)ViewBag.enCokCikanCorbalar)
                    </div>
                </div>

                <div class="chart-card">
                    <div class="chart-wrapper">
                        @Html.Partial("_KahvaltıStaticPartial.cshtml", (IEnumerable<dynamic>)ViewBag.sabahyemeği)
                    </div>
                </div>

                <div class="chart-card">
                    <div class="chart-wrapper">
                        @Html.Partial("_AnaYemekStaticPartial.cshtml", (IEnumerable<dynamic>)ViewBag.Anayemek)
                    </div>
                </div>
            </div>
        </div>

        <!-- Sağ Reklam Alanı -->
        <aside class="ad-right d-flex flex-column align-items-center order-1 order-lg-3">
            <div class="ad-banner small">
                <ins class="adsbygoogle"
                     style="display:block;width:100%;height:auto"
                     data-ad-client="ca-pub-5290089711270021"
                     data-ad-slot="4527260997"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
            </div>
            
            <div class="ad-banner d-none d-lg-block">
                <ins class="adsbygoogle"
                     style="display:block;width:100%;height:auto"
                     data-ad-client="ca-pub-5290089711270021"
                     data-ad-slot="6239782008"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
            </div>
        </aside>
    </div>

    <script>
        // Loading spinner gösterimi
        document.getElementById('selectedCity').addEventListener('change', function() {
            document.getElementById('loadingSpinner').style.display = 'block';
            document.querySelector('.charts-grid').style.opacity = '0.5';
        });
    </script>